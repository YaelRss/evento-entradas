# --- CONFIGURACIÓN DE STRIPE ---
# Tu clave secreta de Stripe (Secret Key) que empieza con sk_test_ o sk_live_
STRIPE_SECRET_KEY=sk_test_...

# Clave secreta del Webhook de Stripe (Signing Secret) que empieza con whsec_
# La obtienes tras registrar el endpoint del webhook en el panel de Stripe
STRIPE_WEBHOOK_SECRET=whsec_...


# --- CONFIGURACIÓN DE SUPABASE ---
# URL de tu base de datos de Supabase
SUPABASE_URL=https://your-project.supabase.co

# Clave de rol de servicio (Service Role Key) de Supabase (¡NUNCA LA EXPONGAS EN EL FRONTEND!)
SUPABASE_SERVICE_ROLE_KEY=ey...


# --- CONFIGURACIÓN DE CORREO (NODEMAILER) ---
# Tu correo de Gmail que enviará las entradas
GMAIL_USER=tu-correo@gmail.com

# Contraseña de aplicación generada en la configuración de seguridad de Google
GMAIL_PASS=xxxx-xxxx-xxxx-xxxx
